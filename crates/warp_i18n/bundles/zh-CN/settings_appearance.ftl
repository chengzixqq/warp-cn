# 外观设置页字符串。
# Keys MUST start with `settings-appearance-`.

settings-appearance-title = 外观
settings-appearance-directory-tab-colors = 目录标签页颜色
settings-appearance-tab-colors-description = 根据您所在的目录或仓库自动为标签页着色。
settings-appearance-uniform-padding = 统一内边距（px）
settings-appearance-line-height = 行高
settings-appearance-font-weight = 字体粗细
settings-appearance-font-size-px = 字体大小（px）
settings-appearance-add-directory = + 添加目录…
settings-appearance-add-directory-color = 添加目录颜色

# 输入位置 / 命令面板项
settings-appearance-input-start-top = 在顶部启动输入框
settings-appearance-input-pin-top = 输入框固定到顶部
settings-appearance-input-pin-bottom = 输入框固定到底部
settings-appearance-toggle-input-mode = 切换输入模式（Warp / 经典）
settings-appearance-show-code-review-tab = 在标签栏显示代码评审按钮
settings-appearance-hide-code-review-tab = 在标签栏隐藏代码评审按钮

# 标签栏
settings-appearance-tab-always-show = 始终显示标签栏
settings-appearance-tab-hide-fullscreen = 全屏时隐藏标签栏
settings-appearance-tab-hover-only = 仅在悬停时显示标签栏

# 全屏
settings-appearance-fullscreen-apps = 全屏应用

# 主题 & 图标
settings-appearance-create-custom-theme = 创建你的自定义主题
settings-appearance-sync-with-os = 跟随系统
settings-appearance-sync-with-os-desc = 当系统切换时，自动在明亮和暗黑主题之间切换。
settings-appearance-current-theme = 当前主题
settings-appearance-icon = 图标
settings-appearance-customize-app-icon = 自定义应用图标
settings-appearance-restart-icon-hint = 你可能需要重启 Warp 才能让 macOS 应用所选图标样式。

# 窗口
settings-appearance-custom-window-size = 以自定义尺寸打开新窗口
settings-appearance-window-opacity = 窗口不透明度：
settings-appearance-window-opacity-value = 窗口不透明度：{$value}
settings-appearance-window-blur-radius = 窗口模糊半径：{$value}
settings-appearance-zoom = 缩放
settings-appearance-zoom-desc = 调整所有窗口的默认缩放级别
settings-appearance-transparency-not-supported = 你的图形驱动不支持透明效果。
settings-appearance-graphics-no-transparent = 当前图形设置可能不支持渲染透明窗口。
settings-appearance-use-window-blur = 使用窗口模糊（亚克力质感）
settings-appearance-hardware-no-transparent = 当前硬件可能不支持渲染透明窗口。
settings-appearance-tools-panel-consistent = 工具面板可见性在标签页之间保持一致

