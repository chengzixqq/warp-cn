#!/usr/bin/env bash
# Fetch upstream/master, attempt a merge into a fresh sync/<date> branch,
# and surface the result via stdout + GITHUB_OUTPUT (when run from Actions).
#
# Exit codes:
#   0  clean merge (sync branch retained, ready for PR)
#   1  unexpected error (network, missing remote, etc.)
#   2  merge conflict (sync branch retained with conflict-state WIP commit)
#
# Env overrides:
#   UPSTREAM_REMOTE  (default: upstream)
#   UPSTREAM_BRANCH  (default: master)
#   UPSTREAM_URL     (default: https://github.com/warpdotdev/warp.git)
#   BASE_BRANCH      (default: master)

set -euo pipefail
cd "$(dirname "$0")/.."

UPSTREAM_REMOTE="${UPSTREAM_REMOTE:-upstream}"
UPSTREAM_BRANCH="${UPSTREAM_BRANCH:-master}"
UPSTREAM_URL="${UPSTREAM_URL:-https://github.com/warpdotdev/warp.git}"
BASE_BRANCH="${BASE_BRANCH:-master}"
SYNC_BRANCH="sync/$(date -u +%Y%m%d-%H%M)"

emit() {
  # Write key=value to GITHUB_OUTPUT if running in Actions; always echo locally.
  echo "$1"
  if [ -n "${GITHUB_OUTPUT:-}" ]; then
    echo "$1" >> "$GITHUB_OUTPUT"
  fi
}

emit_multiline() {
  # Multi-line output: needed when value contains newlines (e.g. file list).
  local key="$1" value="$2" delim="__EOF_${RANDOM}_${RANDOM}__"
  if [ -n "${GITHUB_OUTPUT:-}" ]; then
    {
      echo "${key}<<${delim}"
      printf '%s\n' "$value"
      echo "${delim}"
    } >> "$GITHUB_OUTPUT"
  fi
}

# Ensure upstream remote points at the canonical URL.
if git remote get-url "$UPSTREAM_REMOTE" >/dev/null 2>&1; then
  git remote set-url "$UPSTREAM_REMOTE" "$UPSTREAM_URL"
else
  git remote add "$UPSTREAM_REMOTE" "$UPSTREAM_URL"
fi

# Full history is required: the fork's merge-base with upstream can be hundreds of
# commits deep (487 as of 2026-06, at upstream 35cb40c3 / 2026-05-10). A shallow
# `--depth N` fetch that doesn't reach the merge-base makes git treat the two
# histories as unrelated ("refusing to merge unrelated histories") and abort. We
# already share history up to the last sync, so a full fetch only transfers the new
# upstream commits, not the entire repo.
git fetch "$UPSTREAM_REMOTE" "$UPSTREAM_BRANCH"

# Make sure the local base branch is up to date with origin (where CI's checkout lands).
git fetch origin "$BASE_BRANCH" 2>/dev/null || true

git checkout -B "$SYNC_BRANCH" "origin/$BASE_BRANCH" 2>/dev/null \
  || git checkout -B "$SYNC_BRANCH" "$BASE_BRANCH"

emit "sync_branch=$SYNC_BRANCH"

if git merge --no-ff "$UPSTREAM_REMOTE/$UPSTREAM_BRANCH" \
     -m "chore(sync): merge upstream/$UPSTREAM_BRANCH"; then
  echo "::notice::clean merge into $SYNC_BRANCH"
  emit "status=clean"
  exit 0
fi

# `git merge` exited non-zero. Distinguish a real conflicted merge (MERGE_HEAD set,
# merge started and stopped) from a pre-merge fatal where no merge ever began (e.g.
# "refusing to merge unrelated histories", a bad ref, or a fetch problem). In the
# latter there is nothing to finalize or snapshot, so surface it as a hard error
# instead of mis-reporting a clean sync (COUNT would be 0 with no merge in flight).
if ! git rev-parse -q --verify MERGE_HEAD >/dev/null; then
  echo "::error::git merge failed before starting (no MERGE_HEAD) — likely unrelated histories or a fetch problem; not a content conflict"
  emit "status=error"
  exit 1
fi

# Conflict path: capture conflicted paths, snapshot the conflict state as a WIP commit
# (so the branch is pushable and humans can pick up where the merge left off).
# IMPORTANT: only stage tracked files (`-u`); never `-A`, which would sweep in
# whatever happens to be untracked in the workdir (e.g. sibling workflow files
# being edited in the same checkout).
CONFLICTS="$(git diff --name-only --diff-filter=U | sort -u)"
COUNT="$(printf '%s\n' "$CONFLICTS" | grep -c . || true)"

# rerere.autoupdate + the i18n-aware merge driver can auto-resolve every hunk: the
# index then has zero unmerged paths (COUNT=0) even though `git merge` exited
# non-zero (a conflicted merge always stops before committing for human review).
# That is effectively a clean sync — finalize the merge commit and report clean so
# the i18n-lint + open-pr path runs (a reviewable PR), instead of filing a bogus
# "0 file(s)" conflict issue or silently orphaning the fully-resolved branch.
if [ "$COUNT" -eq 0 ]; then
  echo "::notice::merge fully auto-resolved (rerere); finalizing as clean sync"
  git commit --no-edit --no-verify
  emit "status=clean"
  exit 0
fi

echo "::warning::merge conflicts in $COUNT file(s)"
printf '%s\n' "$CONFLICTS"

emit "status=conflict"
emit "conflict_count=$COUNT"
emit_multiline "conflicts" "$CONFLICTS"

git add -u
git commit --no-verify -m "WIP: unresolved upstream merge conflicts ($COUNT files)" || true

exit 2
